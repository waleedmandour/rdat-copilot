# ── RDAT Copilot — Backend Environment Variables ──────────────────
#
# Copy this file to .env for local development.
# When using Docker, these are set in docker-compose.yml.
#
# Phase 3: CI/CD & Deployment

# SQLite database path (default: rdat_copilot.db in working directory)
# In Docker, use /data/rdat_copilot.db with a volume mount
RDAT_DB_PATH=rdat_copilot.db

# Ollama API base URL (default: http://localhost:11434)
# In Docker, use http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model for translation (default: qwen2.5:7b)
# Other options: llama3.1:8b, mistral:7b, gemma2:9b
OLLAMA_MODEL=qwen2.5:7b

# Uvicorn settings
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=1
