# ── RDAT Copilot — Frontend Environment Variables ──────────────────
#
# Copy this file to .env.local for local development.
# For GitHub Pages deployment, these are set as build args.
#
# Phase 3: CI/CD & Deployment

# Local FastAPI backend URL (default: http://localhost:8000)
# When using Docker, this remains http://localhost:8000
# When deployed, users configure this in Settings
NEXT_PUBLIC_LOCAL_BACKEND_URL=http://localhost:8000
